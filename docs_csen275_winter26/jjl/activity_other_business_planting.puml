@startuml Activity_OtherBusiness_Planting
title Other Business Activity - Planting a Plant

skinparam backgroundColor white
skinparam shadowing false
skinparam ranksep 110
skinparam nodesep 80
skinparam Padding 18
skinparam ArrowThickness 1
skinparam linetype ortho

start
partition "User" {
  :Select plant type;
  :Click an empty tile;
}

partition "GardenGridPanel" {
  :Read selected plant type;
  :Build GridPosition(row, column);
}

partition "GardenController" {
  :plantSeed(PlantType, GridPosition);
  :Create concrete Plant object;
}

partition "GardenPlot" {
  :Validate position;
}

if (GridPosition invalid or occupied?) then (yes)
  partition "GardenController" {
    :Return false;
  }
  partition "GardenGridPanel" {
    :Keep current UI state;
  }
  stop
else (no)
  partition "GardenPlot" {
    :Add plant into plantMap;
    :Increase total/living counts;
    :Locate target garden zone;
  }
endif

partition "GardenZone" {
  :Add plant into zone list;
}

partition "GardenController" {
  :Return true;
}

partition "GardenGridPanel" {
  :updateTile(row, col);
  :Show plant tile and tooltip;
}

partition "User" {
  :See the new plant in the garden;
}
stop
@enduml
