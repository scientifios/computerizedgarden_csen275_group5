  UC_API_Rain((Trigger Rain Event<br/>rain amount))
  UC_API_Temp((Trigger Temperature Event<br/>temperature tempF))
  UC_API_Parasite((Trigger Parasite Infestation<br/>parasite type))
  UC_API_Plants((Get Plants Info<br/>getPlants))
